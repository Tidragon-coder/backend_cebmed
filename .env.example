# Core
NODE_ENV=development
PORT=3000

# Prisma / PostgreSQL
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth
JWT_SECRET=change_me_super_secret_key

## notification
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json
REMINDER_WINDOW_MINUTES= X minutes

# Legacy pg client (optional, only needed while src/db.ts is still used)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cebmed_database
# Brevo
BREVO_API_KEY=
BREVO_LIST_ID=
BREVO_SENDER_EMAIL=noreply@cebmed.fr
BREVO_SENDER_NAME=CebMed

# URL publique de l'API (pour les liens de vérification email)
APP_URL=https://ton-domaine.fr/cebmed
